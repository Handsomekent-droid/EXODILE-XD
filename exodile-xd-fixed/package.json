    "terser": "^5.44.1",
    "lz-string": "1.5.0",
    "jszip": "^3.10.1",
    "js-confuser": "^1.1.0",
    "javascript-obfuscator": "^4.1.1",
    "better-sqlite3": "^12.5.0",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "file-type": "^16.5.4",
