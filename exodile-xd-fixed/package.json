{
  "name": "exodile-xd",
  "version": "6.0.0",
  "description": "EXODILE XD — WhatsApp Bot by Dev Prime Killer Nova Kent",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "data": "data",
    "plugins": "plugins"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "start:optimized": "node --max-old-space-size=2048 --optimize-for-size --gc-interval=100 index.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop:pm2": "pm2 stop exodile",
    "restart:pm2": "pm2 restart exodile",
    "logs:pm2": "pm2 logs exodile",
    "monitor": "pm2 monit",
    "cleanup": "node cleanup.js",
    "start:clean": "npm run cleanup && npm run start:optimized",
    "install:panel": "npm install --legacy-peer-deps",
    "install:force": "npm install --force",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "exodile-xd",
    "whatsapp-bot",
    "whatsapp-api",
    "baileys-bot",
    "exodile",
    "multi-device",
    "prime-kent-bot"
  ],
  "license": "MIT",
  "author": "Dev Prime Killer Nova Kent",
